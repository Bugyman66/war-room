{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "TWITTER_BEARER_TOKEN",
        "NEWS_API_KEY",
        "YOUTUBE_API_KEY",
        "REDIS_URL",
        "RAPIDAPI_KEY",
        "GNEWS_API_KEY",
        "DATABASE_URL",
        "GEMINI_API_KEY",
        "ADMIN_TOKEN"
      ]
    },
    "dev": {
      "cache": false
    },
    "lint": {},
    "test": {}
  }
}
